# Koneksi database PostgreSQL lokal (tanpa SSL untuk dev)
DATABASE_URL=postgres://postgres:12345@127.0.0.1:5432/ujian_online?sslmode=disable

# Kunci rahasia untuk menandatangani JWT. GANTI di produksi!
JWT_ACCESS_SECRET=dev-access-secret-ganti-di-produksi-minimal-32-karakter
JWT_REFRESH_SECRET=dev-refresh-secret-ganti-di-produksi-minimal-32-karakter

# Masa berlaku token
ACCESS_TTL_MIN=15
REFRESH_TTL_DAYS=7

# Port server backend
PORT=3000

# Origin frontend yang diizinkan (CORS)
FRONTEND_ORIGIN=http://localhost:5173
